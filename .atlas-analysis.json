  "keyFeatures": [
    "Real-time desk reservation system with WebSocket synchronization",
    "Geolocation-based attendance verification",
    "Administrative dashboard for managing reservations and users",
    "Desk rotation policy enforcement",
    "Time-window based confirmation system",
    "Multi-shift scheduling (AM, PM, full day)",
    "Interactive visual desk selection interface"
