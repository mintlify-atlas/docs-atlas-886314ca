    "/api/working-horarios - Schedule and time slot management",
    "/api/working-puestos - Desk/seat management",
    "useRealtimeSync - Custom hook for WebSocket synchronization",
    "useAutoCancelarReservas - Hook for automatic reservation cancellation",
